# Credentials and tokens (contain secrets / PII)
credentials.json
token*.json
**/.env

# macOS launchd (contains local paths)
*.plist
# Exception: harvester plist templates are tracked. Local paths are rewritten
# by scripts/install-launchd.sh at install time — see launchagents/README.md.
!launchagents/*.plist

# Data directory (backups, workplans, changelogs — large, contain PII)
data/
!dashboard/server/data/
!dashboard/server/data/linkedin-crm.json

# Machine-learned memory (user-specific, gitignored)
memory.json

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Dashboard (Nuxt)
dashboard/node_modules/
dashboard/.nuxt/
dashboard/.output/
dashboard/.data/
